rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Packages: Public read, Admin write
    match /packages/{packageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Flights: Admin only
    match /flight_bookings/{id} {
      allow read, write: if isAdmin();
    }

    // Hotels: Admin only
    match /hotel_bookings/{id} {
      allow read, write: if isAdmin();
    }

    // Settings: Public read, Admin write
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Contact Requests: Public create, Admin read/write
    match /contact_requests/{requestId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    // Services: Public read, Admin write
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Admin list check
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
    }

    // Slides: Public read, Admin write
    match /slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
